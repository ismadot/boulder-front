# Boulder Analyzer — environment variables
#
# Copy this file to .env.local for local overrides (never commit .env.local).
# In Vercel: set these in Project Settings → Environment Variables.

# ── API server ──────────────────────────────────────────────────────
# Base URL of the boulder-analyzer backend. No trailing slash, no /api suffix.
# Leave empty in development — Vite proxy handles /api automatically.
# Example: https://api.boulder-analyzer.com
VITE_API_URL=

# ── Firebase ────────────────────────────────────────────────────────
# Get these values from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
