# Boulder Analyzer — environment variables
#
# Copy this file to .env.local for local overrides (never commit .env.local).
#
# In production (Vercel) set this in Project Settings → Environment Variables.
# Value: the base URL of your boulder-analyzer API server, no trailing slash.
# Example: https://api.boulder-analyzer.com
#
# Leave empty (or omit) in development — Vite's proxy handles /api.
VITE_API_URL=
